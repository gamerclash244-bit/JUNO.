# Copy this to .env and fill in your values
# NEVER commit .env to git

MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/juno-store
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your_secure_admin_password
PORT=5000
FRONTEND_URL=https://your-juno-site.vercel.app

# Optional: email notifications for orders
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
